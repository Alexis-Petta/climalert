# Alert thresholds
CLIMALERT_MAX_TEMP_C=35
CLIMALERT_MIN_HUMIDITY=60

# Mail notification
CLIMALERT_MAIL_ENABLED=true
SPRING_MAIL_HOST=localhost
SPRING_MAIL_PORT=1025
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
