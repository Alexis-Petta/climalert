@startuml
title Climalert - Diagrama de Componentes

skinparam componentStyle rectangle
skinparam shadowing false

actor "WeatherAPI" as weather
actor "SMTP Server" as smtp

database "H2 local\nHistorial + Alertas" as db

component "Climalert\nSpring Boot" as app {
  component "WeatherPollingScheduler\n@Scheduled 5 min" as poller
  component "WeatherApiClient\nREST /current.json" as client
  component "WeatherHistoryService" as history
  component "AlertAnalysisScheduler\n@Scheduled 1 min" as analyzer
  component "WeatherAlertService" as alerts
  component "AlertEvaluator" as evaluator
  component "EmailAlertNotifier" as mailer
}

poller --> client
client --> weather
poller --> history
history --> db
analyzer --> alerts
alerts --> evaluator
alerts --> db
alerts --> mailer
mailer --> smtp

@enduml
